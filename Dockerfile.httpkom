FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    git+https://github.com/osks/pylyskom.git \
    git+https://github.com/osks/httpkom.git

COPY httpkom.cfg /httpkom.cfg

EXPOSE 5001

CMD ["python", "-m", "httpkom", "--config", "/httpkom.cfg", "--host", "0.0.0.0", "--port", "5001"]
